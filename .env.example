# Optional overrides for headless systems or users who prefer fixed folders.
# Windows example: C:\Users\YourName\Pictures\Yang-gumi\Portrait
YANGGUMI_PORTRAIT_DIR=/home/your-name/Pictures/Yang-gumi/Portrait
YANGGUMI_WALLPAPER_DIR=/home/your-name/Pictures/Yang-gumi/Wallpaper

# Read-only sharing is normally started by share_public.py; do not commit tokens.
YANGGUMI_READ_ONLY=0
